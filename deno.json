{
    "imports": {
        "@libsql/client": "npm:@libsql/client@^0.17.3",
        "drizzle-kit": "npm:drizzle-kit@^0.31.10",
        "drizzle-orm": "npm:drizzle-orm@^0.45.2",
        "hono": "jsr:@hono/hono@^4.12.23",
        "jose": "npm:jose@^5.10.0",
        "dotenv": "jsr:@std/dotenv@^0.225.7"
    },
    "tasks": {
        "start": "deno run -A --env main.ts",
        "db:gen": "deno -A --env drizzle-kit generate",
        "db:mig": "deno -A --env drizzle-kit migrate",
        "db:psh": "deno -A --env drizzle-kit push"
    },
    "compilerOptions": {
        "jsx": "precompile",
        "jsxImportSource": "hono/jsx"
    },
    "fmt": {
        "indentWidth": 4
    }
}
